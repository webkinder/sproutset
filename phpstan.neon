includes:
    - vendor/larastan/larastan/extension.neon
    - vendor/nesbot/carbon/extension.neon
    - phar://phpstan.phar/conf/bleedingEdge.neon

parameters:

    paths:
        - src
        - tests

    scanFiles:
        - vendor/php-stubs/wordpress-stubs/wordpress-stubs.php

    level: max

    tmpDir: /tmp/phpstan

    ignoreErrors:
        - identifier: method.internalClass
        # Larastan's `view()` helper stub declares a conditional return type
        # (`$view is null ? Factory : View`) that fails to narrow at this
        # level, always reporting `Factory|View` even for a non-null literal
        # view name. Verified with a minimal `view('welcome', [])` repro.
        - identifier: return.type
          path: src/View/Components/Image.php
