{
    "name": "webkinder/sproutset",
    "description": "Modern responsive image management for projects using the Roots Acorn framework.",
    "type": "library",
    "keywords": ["wordpress", "acorn", "roots", "responsive-images", "image-optimization", "blade"],
    "homepage": "https://github.com/webkinder/sproutset",
    "license": "GPL-3.0-or-later",
    "authors": [
        {
            "name": "Marco Luzi",
            "email": "marco@webkinder.ch"
        }
    ],
    "support": {
        "issues": "https://github.com/webkinder/sproutset/issues",
        "source": "https://github.com/webkinder/sproutset"
    },
    "require": {
        "php": "^8.3",
        "roots/acorn": "^6.2",
        "spatie/laravel-package-tools": "^1.93"
    },
    "require-dev": {
        "driftingly/rector-laravel": "^2.5",
        "larastan/larastan": "^3.10",
        "laravel/pint": "^1.29",
        "orchestra/testbench": "^11.1",
        "pestphp/pest": "^4.7",
        "php-stubs/wordpress-stubs": "^7.0",
        "rector/rector": "^2.5"
    },
    "autoload": {
        "psr-4": {
            "Webkinder\\Sproutset\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Webkinder\\Sproutset\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "sort-packages": true
    },
    "scripts": {
        "lint": [
            "rector",
            "pint --parallel"
        ],
        "lint:check": [
            "rector --dry-run",
            "pint --parallel --test"
        ],
        "types:check": [
            "phpstan analyse"
        ],
        "test": [
            "pest"
        ],
        "check": [
            "@lint:check",
            "@types:check",
            "@test"
        ]
    },
    "extra": {
        "acorn": {
            "providers": [
                "Webkinder\\Sproutset\\SproutsetServiceProvider"
            ]
        }
    }
}
